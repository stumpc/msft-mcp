{
  "generatorType": "aspnet-classic-greenfield",
  "language": "dotnet",
  "appType": "aspnetclassic",
  "decision": {
    "intent": "onboard",
    "solution": "applicationinsights-web",
    "rationale": "Classic ASP.NET greenfield application (.NET Framework). Microsoft.ApplicationInsights.Web v3.x provides automatic instrumentation with zero code changes — the NuGet package auto-configures HTTP modules and telemetry pipeline."
  },
  "actions": [
    {
      "id": "review-education",
      "type": "review-education",
      "title": "Review educational materials before implementation",
      "resources": [
        "learn://concepts/dotnet/aspnet-classic-appinsights.md",
        "learn://api-reference/dotnet/ApplicationInsightsWeb.md",
        "learn://examples/dotnet/aspnet-classic-setup.md"
      ]
    },
    {
      "id": "add-appinsights-package",
      "type": "add-package",
      "title": "Add Application Insights Web SDK package",
      "dependsOn": "review-education",
      "packageManager": "nuget-pm",
      "packageName": "Microsoft.ApplicationInsights.Web",
      "version": "latest-stable"
    },
    {
      "id": "validate-install",
      "type": "validate-install",
      "title": "Verify package auto-configured Web.config and created ApplicationInsights.config",
      "dependsOn": "add-appinsights-package",
      "filesToExist": [
        "ApplicationInsights.config"
      ],
      "fileContentChecks": {
        "Web.config": [
          "ApplicationInsightsHttpModule",
          "TelemetryHttpModule"
        ]
      }
    },
    {
      "id": "add-connection-string",
      "type": "add-config",
      "title": "Configure Application Insights connection string",
      "dependsOn": "validate-install",
      "targetFile": "ApplicationInsights.config",
      "configKey": "ConnectionString",
      "configValue": "<your-connection-string>",
      "configFormat": "xml",
      "validationKey": "APPLICATIONINSIGHTS_CONNECTION_STRING"
    }
  ]
}
